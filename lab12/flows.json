        "func": "// Отримуємо поточні значення датчиків\nconst rad = global.get(\"alm.sp.radHI\") ?? global.get(\" alm.sp.radHI\") ?? 0;\nconst val = global.get(\"alm.sp.valHI\") ?? global.get(\" alm.sp.valHI\") ?? 0;\n\nlet activeAlarms = [];\n\n// Порівнюємо значення з критичними уставками\n// Якщо радіація більша за 10(зміни число на своє, якщо треба)\nif (Number(rad) > 10) {\n    activeAlarms.push(\" Перевищення радіації\");\n}\n\n// Якщо синус (VAL) більший за уставку 2\nif (Number(val) > 2) {\n    activeAlarms.push(\" перевищення синуса \");\n}\n\nlet messageText = \"\";\n\n// Перевірка згідно з ТЗ лабораторної\nif (activeAlarms.length === 0) {\n    messageText = \"Немає активних тривог\";\n} else {\n    // Об'єднуємо тривоги, щоб кожна була з нового рядка\n    messageText = activeAlarms.join(\"\\n\");\n}\n\n// Формуємо payload для Telegram\nmsg.payload = {\n    chatId: msg.payload.chatId,\n    type: \"message\",\n    content: messageText\n};\n\nreturn msg;",
